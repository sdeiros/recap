---
import "../styles/global.css";
const title = "FAIXA — sua escuta em cartaz";
const desc = "Estatísticas do seu Last.fm viram cartaz pronto pra Stories e Status.";
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>{title}</title>
    <meta name="description" content={desc} />
    <meta name="theme-color" content="#0D0D0F" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="icon" href="/icone.svg" type="image/svg+xml" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={desc} />
    <meta property="og:type" content="website" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Anton&family=Archivo:wght@400;500;600;700&family=Courier+Prime:wght@400;700&family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@400;500;700&family=Syne:wght@600;700;800&display=swap"
    />
  </head>
  <body>
    <!-- ===================== ENTRADA ===================== -->
    <section class="entrada" id="tela-entrada">
      <div class="cartao-entrada">
        <div class="marca">
          <b>FAIXA</b>
          <i></i>
        </div>

        <h1 class="titulo">Sua escuta<br /><em>em cartaz.</em></h1>
        <p class="sub">
          Semana, mês ou o ano inteiro do seu Last.fm, em imagem pronta pra Stories e Status.
          Só o @ — sem senha.
        </p>

        <!-- instalação da chave (some no modo servidor) -->
        <div class="bloco oculto" id="box-chave">
          <span class="rotulo">configuração · uma vez</span>
          <input type="text" id="inp-chave" placeholder="cole sua API key do Last.fm" autocomplete="off" />
          <p class="dica">
            Gratuita e instantânea em <b>last.fm/api/account/create</b>. Fica guardada só neste
            navegador.
          </p>
          <button class="btn" id="btn-chave">Guardar</button>
        </div>

        <!-- login -->
        <div class="bloco oculto" id="box-login">
          <div class="campo-at">
            <span>@</span>
            <input type="text" id="inp-user" placeholder="seu usuário do last.fm" autocomplete="username" />
          </div>
          <p class="erro oculto" id="erro"></p>
          <button class="btn" id="btn-entrar">Entrar</button>
          <div style="display:flex;gap:14px;align-items:center">
            <button class="link" id="btn-demo">ver demonstração</button>
            <button class="link" id="btn-trocar-chave">trocar chave</button>
          </div>
        </div>
      </div>
    </section>

    <!-- ===================== APLICAÇÃO ===================== -->
    <div class="app oculto" id="tela-app">
      <header class="topbar">
        <div class="marca">
          <b>FAIXA</b>
          <i></i>
        </div>
        <div class="segmento" id="periodos" role="group" aria-label="Período"></div>
        <div class="passo oculto" id="passo">
          <button id="passo-ant" aria-label="Período anterior">‹</button>
          <b id="passo-rotulo"></b>
          <button id="passo-prox" aria-label="Período seguinte">›</button>
        </div>
        <span class="carregando oculto" id="carregando">atualizando…</span>
        <div class="espaco"></div>
        <div class="usuario">
          <span id="quem"></span>
          <button class="link" id="btn-sair">sair</button>
        </div>
      </header>

      <div class="corpo">
        <!-- ---------- painel de controles ---------- -->
        <aside class="painel">
          <nav class="abas" role="tablist" aria-label="Seções">
            <button role="tab" data-aba="cartaz" aria-selected="true">Cartaz</button>
            <button role="tab" data-aba="numeros" aria-selected="false">Números</button>
            <button role="tab" data-aba="tops" aria-selected="false">Tops</button>
          </nav>

          <!-- aba cartaz -->
          <div id="aba-cartaz" style="display:grid;gap:20px">
            <div class="bloco">
              <span class="rotulo">estilo</span>
              <div class="opcoes" id="op-layout"></div>
              <p class="dica" id="dica-layout-periodo"></p>
            </div>
            <div class="bloco">
              <span class="rotulo">formato</span>
              <div class="opcoes" id="op-res"></div>
            </div>
            <div class="bloco">
              <span class="rotulo">cores do cartaz</span>
              <div class="paletas" id="op-tema"></div>
              <div class="cores-custom oculto" id="cores-custom">
                <label><span>fundo</span><input type="color" id="cor-bg" /></label>
                <label><span>texto</span><input type="color" id="cor-text" /></label>
                <label><span>destaque</span><input type="color" id="cor-accent" /></label>
                <label><span>contraponto</span><input type="color" id="cor-accent2" /></label>
                <button class="link" id="btn-reset-cores" type="button">restaurar cores</button>
              </div>
              <p class="dica">As fotos continuam intactas; a paleta recolore apenas o projeto gráfico.</p>
            </div>
            <div class="bloco">
              <span class="rotulo">assinatura</span>
              <input type="text" id="inp-assinatura" maxlength="42" placeholder="ex: ouvindo no YouTube Music" />
              <label class="caixa">
                <input type="checkbox" id="chk-handle" />
                usar meu @ quando vazio
              </label>
              <p class="dica">Deixe vazio e o cartaz sai sem identificação.</p>
            </div>
          </div>

          <!-- aba números -->
          <div id="aba-numeros" class="oculto" style="display:grid;gap:20px">
            <div class="metricas" id="metricas"></div>
            <div class="bloco">
              <span class="rotulo">relógio · últimas 200 reproduções</span>
              <div class="relogio" id="relogio"></div>
              <p class="dica">Sempre os 200 mais recentes, independente do período.</p>
            </div>
            <div class="bloco" id="bloco-estimativa"></div>
          </div>

          <!-- aba tops -->
          <div id="aba-tops" class="oculto" style="display:grid;gap:20px">
            <div class="bloco">
              <span class="rotulo">artistas</span>
              <div class="lista" id="lista-artistas"></div>
            </div>
            <div class="bloco">
              <span class="rotulo">músicas</span>
              <div class="lista" id="lista-musicas"></div>
            </div>
            <div class="bloco">
              <span class="rotulo">álbuns</span>
              <div class="lista" id="lista-albuns"></div>
            </div>
          </div>
        </aside>

        <!-- ---------- palco ---------- -->
        <main class="palco">
          <div class="moldura"><canvas id="cartaz" role="img" aria-label="Prévia do cartaz"></canvas></div>
          <div class="acoes">
            <button class="btn" id="btn-baixar">Baixar PNG</button>
            <span class="nota" id="nota-res"></span>
          </div>
        </main>
      </div>
    </div>

    <script>
      import * as C from "../scripts/cartaz.js";
      import * as LF from "../scripts/lastfm.js";

      const $ = (s) => document.querySelector(s);
      const esc = (v) =>
        String(v).replace(/[&<>"']/g, (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" })[c]);

      const el = {
        entrada: $("#tela-entrada"),
        app: $("#tela-app"),
        boxChave: $("#box-chave"),
        boxLogin: $("#box-login"),
        inpChave: $("#inp-chave"),
        inpUser: $("#inp-user"),
        erro: $("#erro"),
        carregando: $("#carregando"),
        canvas: $("#cartaz"),
        quem: $("#quem"),
      };

      const VISUAL_SLOT = "faixa:visual-v11";
      const CORES_PADRAO = { bg: "#0D0D0F", text: "#FFFFFF", accent: "#FF4A1C", accent2: "#1E2BFF" };
      let visualSalvo = {};
      try {
        visualSalvo = JSON.parse(localStorage.getItem(VISUAL_SLOT) || "{}") || {};
      } catch (_) {
        visualSalvo = {};
      }
      const layoutSalvoExiste = C.LAYOUTS.some((l) => l.id === visualSalvo.layout);
      const temaSalvoExiste = C.THEMES.some((t) => t.id === visualSalvo.themeId);

      let estado = {
        dados: null,
        periodo: "semana",
        offset: 0,
        layout: layoutSalvoExiste ? visualSalvo.layout : C.PERIOD_DEFAULT_LAYOUT.semana,
        layoutManual: layoutSalvoExiste,
        res: C.RESOLUTIONS.some((r) => r.id === visualSalvo.res) ? visualSalvo.res : "story",
        themeId: temaSalvoExiste ? visualSalvo.themeId : "original",
        customColors: { ...CORES_PADRAO, ...(visualSalvo.customColors || {}) },
        demo: false,
        user: "",
        assinatura: "",
        mostrarHandle: false,
      };

      function salvarVisual() {
        try {
          localStorage.setItem(
            VISUAL_SLOT,
            JSON.stringify({
              layout: estado.layout,
              res: estado.res,
              themeId: estado.themeId,
              customColors: estado.customColors,
            })
          );
        } catch (_) {}
      }

      /* ---------------- controles ---------------- */
      const barra = $("#periodos");
      C.PERIODS.forEach((p) => {
        const b = document.createElement("button");
        b.textContent = p.label;
        b.dataset.id = p.id;
        b.dataset.recap = p.recap ? "1" : "0";
        b.setAttribute("aria-pressed", String(p.id === estado.periodo));
        b.onclick = () => trocarPeriodo(p.id, 0);
        barra.appendChild(b);
      });

      function opcoes(alvo, itens, atual, aoEscolher) {
        const cont = $(alvo);
        cont.innerHTML = "";
        itens.forEach((it) => {
          const b = document.createElement("button");
          b.className = "opcao";
          b.setAttribute("aria-pressed", String(it.id === atual()));
          b.innerHTML =
            `<span class="marcador"></span><span class="txt"><b>${esc(it.titulo)}</b>` +
            (it.nota ? `<span>${esc(it.nota)}</span>` : "") +
            `</span>`;
          b.onclick = () => {
            aoEscolher(it.id);
            cont.querySelectorAll(".opcao").forEach((x) => x.setAttribute("aria-pressed", "false"));
            b.setAttribute("aria-pressed", "true");
            desenhar();
          };
          cont.appendChild(b);
        });
      }

      const nomePeriodo = { semana: "semana", mes: "mês", ano: "ano" };

      function botaoLayout(layout, recomendado) {
        const b = document.createElement("button");
        b.className = "opcao opcao-layout";
        b.setAttribute("aria-pressed", String(layout.id === estado.layout));
        b.innerHTML =
          `<span class="marcador"></span><span class="txt"><span class="linha-opcao"><b>${esc(layout.label)}</b>` +
          (recomendado ? `<em>indicado</em>` : "") +
          `</span><span>${esc(layout.note)}</span></span>`;
        b.onclick = () => {
          estado.layout = layout.id;
          estado.layoutManual = true;
          salvarVisual();
          renderLayouts();
          desenhar();
        };
        return b;
      }

      function renderLayouts() {
        const cont = $("#op-layout");
        cont.innerHTML = "";
        const recomendados = C.LAYOUTS.filter((l) => l.best.includes(estado.periodo));
        const outros = C.LAYOUTS.filter((l) => !l.best.includes(estado.periodo));
        const grupo = (titulo, itens, recomendado) => {
          const h = document.createElement("span");
          h.className = "grupo-opcoes-titulo";
          h.textContent = titulo;
          cont.appendChild(h);
          itens.forEach((l) => cont.appendChild(botaoLayout(l, recomendado)));
        };
        grupo(`melhores para ${nomePeriodo[estado.periodo]}`, recomendados, true);
        if (outros.length) grupo("também funcionam", outros, false);
        const atual = C.LAYOUTS.find((l) => l.id === estado.layout);
        const indicado = atual?.best.includes(estado.periodo);
        $("#dica-layout-periodo").textContent = indicado
          ? `${atual.label} aproveita bem os dados deste período.`
          : `${atual?.label || "Este estilo"} continua disponível, mas rende melhor em ${
              (atual?.best || []).map((x) => nomePeriodo[x]).join(" ou ")
            }.`;
      }

      function renderTemas() {
        const cont = $("#op-tema");
        cont.innerHTML = "";
        C.THEMES.forEach((tema) => {
          const b = document.createElement("button");
          b.className = "tema-opcao";
          b.setAttribute("aria-pressed", String(tema.id === estado.themeId));
          const cores = tema.id === "custom"
            ? [estado.customColors.bg, estado.customColors.accent, estado.customColors.accent2]
            : tema.preview;
          b.innerHTML = `<span class="amostras">${cores
            .map((cor) => `<i style="background:${esc(cor)}"></i>`)
            .join("")}</span><span><b>${esc(tema.label)}</b><small>${esc(tema.note)}</small></span>`;
          b.onclick = () => {
            estado.themeId = tema.id;
            salvarVisual();
            renderTemas();
            desenhar();
          };
          cont.appendChild(b);
        });
        $("#cores-custom").classList.toggle("oculto", estado.themeId !== "custom");
      }

      function sincronizarCores() {
        const mapa = { "#cor-bg": "bg", "#cor-text": "text", "#cor-accent": "accent", "#cor-accent2": "accent2" };
        Object.entries(mapa).forEach(([sel, chave]) => {
          const campo = $(sel);
          campo.value = estado.customColors[chave];
          campo.oninput = (e) => {
            estado.customColors = { ...estado.customColors, [chave]: e.target.value };
            estado.themeId = "custom";
            salvarVisual();
            renderTemas();
            desenhar();
          };
        });
      }

      renderLayouts();
      renderTemas();
      sincronizarCores();
      $("#btn-reset-cores").onclick = () => {
        estado.customColors = { ...CORES_PADRAO };
        estado.themeId = "custom";
        sincronizarCores();
        salvarVisual();
        renderTemas();
        desenhar();
      };

      opcoes(
        "#op-res",
        C.RESOLUTIONS.map((r) => ({ id: r.id, titulo: r.label, nota: `${r.w} × ${r.h}` })),
        () => estado.res,
        (id) => {
          estado.res = id;
          salvarVisual();
        }
      );

      document.querySelectorAll('[role="tab"]').forEach((t) => {
        t.onclick = () => {
          document.querySelectorAll('[role="tab"]').forEach((x) => x.setAttribute("aria-selected", "false"));
          t.setAttribute("aria-selected", "true");
          ["cartaz", "numeros", "tops"].forEach((a) =>
            $(`#aba-${a}`).classList.toggle("oculto", a !== t.dataset.aba)
          );
        };
      });

      $("#inp-assinatura").addEventListener("input", (e) => {
        estado.assinatura = e.target.value;
        desenhar();
      });
      $("#chk-handle").addEventListener("change", (e) => {
        estado.mostrarHandle = e.target.checked;
        desenhar();
      });

      /* ---------------- entrada ---------------- */
      async function prepararEntrada() {
        const precisa = await LF.needsBrowserKey();
        el.boxChave.classList.toggle("oculto", !precisa);
        el.boxLogin.classList.toggle("oculto", precisa);
        el.inpUser.value = LF.storedUser();
      }

      $("#btn-chave").onclick = () => {
        const k = el.inpChave.value.trim();
        if (!k) return;
        LF.saveKey(k);
        el.inpChave.value = "";
        prepararEntrada();
      };
      $("#btn-trocar-chave").onclick = () => {
        el.boxChave.classList.remove("oculto");
        el.boxLogin.classList.add("oculto");
      };
      $("#btn-demo").onclick = () => {
        estado.demo = true;
        estado.periodo = "semana";
        estado.offset = 0;
        if (!estado.layoutManual) estado.layout = C.PERIOD_DEFAULT_LAYOUT.semana;
        renderLayouts();
        estado.dados = LF.demo("semana", 0);
        abrirApp();
      };
      $("#btn-entrar").onclick = entrar;
      el.inpUser.addEventListener("keydown", (e) => {
        if (e.key === "Enter") entrar();
      });
      el.inpChave.addEventListener("keydown", (e) => {
        if (e.key === "Enter") $("#btn-chave").click();
      });

      async function entrar() {
        const u = el.inpUser.value.trim();
        if (!u) return;
        ocupado(true);
        el.erro.classList.add("oculto");
        try {
          const d = await LF.load(u, estado.periodo, estado.offset);
          LF.saveUser(u);
          estado = { ...estado, dados: d, demo: false, user: u };
          abrirApp();
        } catch (e) {
          el.erro.textContent = e.message || "Não achei esse @.";
          el.erro.classList.remove("oculto");
        } finally {
          ocupado(false);
        }
      }

      function ocupado(v) {
        el.carregando.classList.toggle("oculto", !v);
        const b = $("#btn-entrar");
        b.disabled = v;
        b.textContent = v ? "Carregando…" : "Entrar";
      }

      $("#btn-sair").onclick = () => {
        estado.dados = null;
        el.app.classList.add("oculto");
        el.entrada.classList.remove("oculto");
      };

      $("#btn-baixar").onclick = () => C.download(el.canvas, estado.layout, estado.res, estado.periodo);

      async function trocarPeriodo(id, offset) {
        if (id === estado.periodo && offset === estado.offset) return;
        estado.periodo = id;
        estado.offset = offset;
        if (!estado.layoutManual) estado.layout = C.PERIOD_DEFAULT_LAYOUT[id] || estado.layout;
        renderLayouts();
        barra.querySelectorAll("button").forEach((b) =>
          b.setAttribute("aria-pressed", String(b.dataset.id === id))
        );
        if (estado.demo) {
          estado.dados = LF.demo(id, offset);
          pintar();
          return;
        }
        ocupado(true);
        try {
          estado.dados = await LF.load(estado.user, id, offset);
          await C.precarregarCapas(estado.dados);
          pintar();
        } catch (e) {
          console.error(e);
        } finally {
          ocupado(false);
        }
      }

      /* navegação entre meses e anos */
      $("#passo-ant").onclick = () => {
        const p = C.PERIODS.find((x) => x.id === estado.periodo);
        if (estado.offset < p.maxOffset) trocarPeriodo(estado.periodo, estado.offset + 1);
      };
      $("#passo-prox").onclick = () => {
        if (estado.offset > 0) trocarPeriodo(estado.periodo, estado.offset - 1);
      };

      function atualizarPasso() {
        const p = C.PERIODS.find((x) => x.id === estado.periodo);
        const caixa = $("#passo");
        caixa.classList.toggle("oculto", p.maxOffset === 0);
        if (p.maxOffset === 0) return;
        const j = C.janela(estado.periodo, estado.offset);
        $("#passo-rotulo").textContent = j.rotulo;
        $("#passo-ant").disabled = estado.offset >= p.maxOffset;
        $("#passo-prox").disabled = estado.offset <= 0;
      }

      /* ---------------- aplicação ---------------- */
      async function abrirApp() {
        el.entrada.classList.add("oculto");
        el.app.classList.remove("oculto");
        await C.ensureAssets();
        await C.precarregarCapas(estado.dados);
        pintar();
      }

      function pintar() {
        const d = estado.dados;
        const p = C.PERIODS.find((x) => x.id === estado.periodo);
        atualizarPasso();
        el.quem.innerHTML = `<b>@${esc(d.user.name)}</b>${estado.demo ? " · demo" : ""}`;

        const delta = d.prevCount > 0 ? Math.round(((d.count - d.prevCount) / d.prevCount) * 100) : null;
        const metricasEl = $("#metricas");
        metricasEl.classList.add("anima");
        metricasEl.innerHTML = [
          [d.count.toLocaleString("pt-BR"), "reproduções"],
          [d.segundos ? C.formatTempo(d.segundos, true) : "—", "tempo"],
          [(d.uniqueArtists || 0).toLocaleString("pt-BR"), "artistas"],
        ]
          .map(([v, r]) => `<div class="metrica"><b data-valor="${esc(v)}">${esc(v)}</b><span>${r}</span></div>`)
          .join("");
        contar(metricasEl.querySelectorAll("b"));

        $("#bloco-estimativa").innerHTML =
          `<p class="dica">${
            delta === null ? "" : `${delta >= 0 ? "↑" : "↓"} ${Math.abs(delta)}% em relação ${p.prev === "semana passada" ? "à" : "ao"} ${p.prev}.<br />`
          }${d.duracaoEstimada ? "O tempo é estimativa: o Last.fm não informou a duração das suas faixas." : "Tempo estimado pela duração média das suas faixas."}</p>`;

        const max = Math.max(1, ...d.clock);
        $("#relogio").innerHTML = d.clock
          .map(
            (v, h) =>
              `<div><i class="${v === max ? "pico" : ""}" style="height:${Math.max(3, (v / max) * 56)}px" title="${h}h · ${v}"></i>${
                h % 6 === 0 ? `<span>${h}</span>` : ""
              }</div>`
          )
          .join("");

        lista("#lista-artistas", d.topArtists, (a) => a.name, () => "");
        lista("#lista-musicas", d.topTracks, (t) => t.name, (t) => t.artist);
        lista("#lista-albuns", d.topAlbums || [], (a) => a.name, (a) => a.artist);

        desenhar();
      }

      function lista(sel, itens, nome, sub) {
        const alvo = $(sel);
        alvo.classList.add("anima");
        alvo.innerHTML = itens
          .slice(0, 8)
          .map(
            (it, i) => `<div class="item">
              <span class="pos">${i + 1}</span>
              <span style="min-width:0">
                <span class="nome">${esc(nome(it))}</span>
                ${sub(it) ? `<span class="sub" style="display:block">${esc(sub(it))}</span>` : ""}
              </span>
              <span class="qtd">${it.playcount}</span>
            </div>`
          )
          .join("");
      }

      /* números sobem até o valor, se forem números */
      function contar(nos) {
        const reduzido = matchMedia("(prefers-reduced-motion: reduce)").matches;
        nos.forEach((no) => {
          const bruto = no.dataset.valor || "";
          const alvo = Number(bruto.replace(/\./g, "").replace(/[^0-9]/g, ""));
          if (reduzido || !alvo || alvo > 1e7 || /[a-z]/i.test(bruto)) return;
          const dur = 620;
          const t0 = performance.now();
          const passo = (t) => {
            const k = Math.min(1, (t - t0) / dur);
            const suave = 1 - Math.pow(1 - k, 3);
            no.textContent = Math.round(alvo * suave).toLocaleString("pt-BR");
            if (k < 1) requestAnimationFrame(passo);
            else no.textContent = bruto;
          };
          requestAnimationFrame(passo);
        });
      }

      function desenhar() {
        if (!estado.dados) return;
        const dados = {
          ...estado.dados,
          assinatura: estado.assinatura,
          mostrarHandle: estado.mostrarHandle,
          themeId: estado.themeId,
          customColors: estado.customColors,
        };
        const res = C.render(el.canvas, estado.layout, estado.res, dados);
        $("#nota-res").textContent = `${res.w} × ${res.h}`;
        /* reinicia a transição de entrada a cada novo desenho */
        el.canvas.classList.remove("trocando");
        void el.canvas.offsetWidth;
        el.canvas.classList.add("trocando");
      }

      prepararEntrada();

      if ("serviceWorker" in navigator) {
        navigator.serviceWorker.register("/sw.js").catch(() => {});
      }
    </script>
  </body>
</html>
